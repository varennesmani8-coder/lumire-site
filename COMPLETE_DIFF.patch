+    // Get product inventory by handle (for stock refresh)
+    async getProductInventory(handle) {
+        const query = `
+            query GetProductInventory($handle: String!) {
+                productByHandle(handle: $handle) {
+                    id
+                    handle
+                    title
+                    variants(first: 50) {
+                        edges {
+                            node {
+                                id
+                                title
+                                quantityAvailable
+                                availableForSale
+                            }
+                        }
+                    }
+                }
+            }
+        `;
+
+        return this.query(query, { handle });
+    }
 }
 
